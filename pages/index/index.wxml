<!--pages/index/index.wxml-->
<view class="game-container">
  <canvas 
    type="2d" 
    id="gameCanvas" 
    class="game-canvas"
    bindtouchstart="touchStart"
    bindtouchmove="touchMove"
    bindtouchend="touchEnd"
  ></canvas>
  
  <view class="ui-overlay" wx:if="{{gameState !== 'PLAYING'}}">
    <view class="title">几何战士</view>
    <button class="start-btn" bindtap="startGame">开始游戏</button>
  </view>
  
  <view class="hud" wx:if="{{gameState === 'PLAYING'}}">
    <text class="score">分数: {{score}}</text>
    <text class="timer">时间: {{timerStr}}</text>
  </view>
</view>
