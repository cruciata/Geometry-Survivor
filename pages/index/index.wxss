.container {
	min-height: 100vh;
	padding: 40rpx;
	box-sizing: border-box;
	background: #0f172a;
}

.title {
	font-size: 56rpx;
	font-weight: 700;
	color: #ffffff;
	margin-bottom: 12rpx;
}

.subtitle {
	font-size: 30rpx;
	color: #93c5fd;
	margin-bottom: 36rpx;
}

.label {
	font-size: 28rpx;
	color: #e2e8f0;
	margin-bottom: 14rpx;
}

.url-input {
	width: 100%;
	height: 88rpx;
	line-height: 88rpx;
	border-radius: 14rpx;
	padding: 0 24rpx;
	box-sizing: border-box;
	background: #1e293b;
	color: #ffffff;
}

.btn {
	margin-top: 24rpx;
	background: #334155;
	color: #ffffff;
	border: none;
	font-size: 30rpx;
}

.btn.primary {
	margin-top: 28rpx;
	background: #2563eb;
}

.tips-title {
	margin-top: 44rpx;
	margin-bottom: 16rpx;
	color: #ffffff;
	font-size: 30rpx;
	font-weight: 600;
}

.tip {
	font-size: 27rpx;
	color: #cbd5e1;
	line-height: 1.8;
}
